# Database Configuration
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=food_traceability
MYSQL_USER=app_user
MYSQL_PASSWORD=your_secure_app_password_here

# Port Configuration (default ports for development)
MYSQL_EXPOSED_PORT=3306
FRONTEND_EXPOSED_PORT=80

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# Application URL (for production, set your domain)
APP_VERIFY_URL=https://your-domain.com

# CORS Configuration (comma-separated list of allowed origins, use * for all)
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# JPA Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# Nginx Configuration
NGINX_HOST=localhost
NGINX_PORT=80
